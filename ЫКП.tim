#Комментарий пишется через решётку и не как не влияет на код.
#Программа переводит все русские ключевые слова на питон, поэтому
#Для любого вывода команды используется классический питон, поэтому стоит быть #аккуратным
а = 10 # тип число
б = Правда # тип логический
в = "строка" #тип срока
г = 0.5 #тип дробь
вывод(а)
вывод(тип(б))
вывод(в)